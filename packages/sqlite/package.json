  },
  "devDependencies": {
    "@gamn9/data": "*",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "better-sqlite3": ">=9.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
