{
  "name": "@lambdaql/compiler",
  "version": "1.0.0",
  "description": "TypeScript Custom Transformer — compiles @lambdaql lambdas to AST at build time",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kimung/lambdaql",
    "directory": "packages/compiler"
  },
  "keywords": [
    "query-builder",
    "typescript",
    "transformer",
    "aot",
    "ts-patch",
    "linq"
  ],
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
