{
  "name": "@gamn9/expression",
  "version": "1.0.0",
  "description": "Parse JS arrow functions into typed ASTs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" }
  },
  "scripts": {
    "build":     "tsc",
    "test":      "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": { "acorn": "^8.14.0" },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript":  "^5.7.0",
    "vitest":      "^2.1.0"
  }
}
