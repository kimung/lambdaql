{
  "name": "@lambdaql/monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build -w @lambdaql/expression && npm run build -w @lambdaql/data && npm run build -w @lambdaql/compiler -w @lambdaql/mikro-orm -w @lambdaql/pg -w @lambdaql/sqlite -w @lambdaql/unplugin",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "husky",
    "version": "changeset version",
    "release": "changeset publish --provenance",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "lint-staged": {
    "**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "tsx": "^4.19.0",
    "typescript-eslint": "^8.61.1",
    "vitepress": "^1.6.3"
  }
}
